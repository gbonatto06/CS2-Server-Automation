# INSTRUCTIONS / INSTRUÇÕES

# 🇺🇸 Rename this file to 'terraform.tfvars' and fill in your values.
#    This file contains sensitive secrets. Do not share with anyone
#
# 🇧🇷 Renomeie este arquivo para 'terraform.tfvars' e preencha com seus valores.
#    Este arquivo contém segredos sensíveis. Não compartilhe com ninguém.
# ---------------------------------------------------------------------------------------------------------------------

# AWS CONFIGURATION / CONFIGURAÇÃO AWS

# 🇺🇸 AWS Region. Use the closest aws region to you. Example: 'sa-east-1' for the lowest latency if you are in Brazil.
# 🇧🇷 Região da AWS. Use a região mais perto possível. Exemplo: 'sa-east-1' para a menor latência se você estiver no Brasil.
aws_region = "sa-east-1"

# 🇺🇸 Instance Type. c6i.xlarge or higher recommended for stable frame times.
# 🇧🇷 Tipo de Instância. c6i.xlarge é recomendada para performance estável (CPU/RAM).
instance_type = "c6i.xlarge"

# 🇺🇸 Project Name. Used to tag resources in AWS Console (e.g., "cs2-server-production").
# 🇧🇷 Nome do Projeto. Usado para etiquetar recursos no console da AWS (ex: "cs2-servidor-producao").
project_name = "cs2-server-automation"

# GAME CONFIGURATION / CONFIGURAÇÃO DO JOGO

# 🇺🇸 Steam GSLT Token (AppID 730). Required for the server to be reachable over the internet.
#    Get yours at: https://steamcommunity.com/dev/managegameservers
# 🇧🇷 Token GSLT da Steam (AppID 730). Obrigatório para o servidor ser acessível pela internet.
#    Obtenha o seu em: https://steamcommunity.com/dev/managegameservers
cs2_gslt_token = "YOUR_TOKEN_HERE"

# 🇺🇸 Server Password.
#    It is highly recommended to set a password.
#    If left empty, the server will be public and might expose Admin privileges depending on MatchZy config.
# 🇧🇷 Senha do Servidor.
#    É altamente recomendado definir uma senha.
#    Se ficar em branco, o servidor será público e pode expor privilégios de Admin dependendo da config do MatchZy.
cs2_server_password = "changeme123"

# --- DATABASE / BANCO DE DADOS ---

# 🇺🇸 Database Password. Used for MySQL (Skins storage). Must be at least 8 characters.
# 🇧🇷 Senha do Banco de Dados. Usada para o MySQL (armazenamento de Skins). Mínimo de 8 caracteres.
db_password = "secure_db_password_123"